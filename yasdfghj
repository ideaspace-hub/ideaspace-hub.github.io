<!DOCTYPE html> 
<html>
<head>
  <title>Apply - CollabSpace</title>
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <style>
    /* Your CSS is unchanged, so skipping it here for brevity */
    body {
      margin: 0;
      font-family: 'Roboto', sans-serif;
      background: none;
      background-size: cover;
      color: #e0e0e0;
    }
    .navbar {
  background: rgba(10, 15, 36, 0.8);
  color: white;
  padding: 18px 20px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: sticky;
  top: 0;
  z-index: 1000;
  backdrop-filter: blur(10px);
  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
}

.nav-links {
  display: flex;
  gap: 20px;
}

.nav-links a {
  color: #8affff;
  text-decoration: none;
  font-weight: 500;
  transition: color 0.3s ease;
}

.nav-links a:hover {
  color: #66ffff;
}

.hamburger {
  display: none;
  font-size: 26px;
  cursor: pointer;
}

/* Mobile styles */
@media (max-width: 768px) {
  .nav-links {
    position: absolute;
    top: 60px;
    left: 0;
    right: 0;
    background: rgba(10, 15, 36, 0.95);
    flex-direction: column;
    text-align: center;
    display: none;
    padding: 15px 0;
  }

  .nav-links a {
    margin: 10px 0;
  }

  .hamburger {
    display: block;
  }

  .nav-links.active {
    display: flex;
  }
}
.nav-links {
  transition: max-height 0.3s ease;
  overflow: hidden;
  max-height: 0;
}

.nav-links.active {
  max-height: 500px; /* adjust if menu gets clipped */
}


    .container {
      max-width: 1200px;
      margin: 50px auto;
      background: rgba(10, 15, 36, 0.75);
      backdrop-filter: blur(15px);
      padding: 40px;
      border-radius: 20px;
      box-shadow: 0 0 30px rgba(0, 0, 0, 0.5);
      color: #e0e0e0;
    }
    h2 {
      text-align: center;
      color: #66ffff;
      margin-bottom: 30px;
      font-size: 2.2rem;
    }
    select, input, textarea {
      width: 100%;
      padding: 12px;
      margin: 10px 0 20px;
      border-radius: 8px;
      border: 1px solid rgba(102, 255, 255, 0.3);
      background: rgba(255,255,255,0.1);
      color: #e0e0e0;
      font-size: 17px;
      outline: none;
      transition: border-color 0.3s ease;
    }
    select:focus, input:focus, textarea:focus {
      border-color: #66ffff;
      box-shadow: 0 0 8px rgba(102, 255, 255, 0.5);
    }
    input::placeholder, textarea::placeholder {
      color: #b0e0e6;
    }

    /* Search bar specific styles */
    #searchContainer {
      position: relative;
      margin-bottom: 30px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    #mainSearchInput {
      flex-grow: 1;
      padding: 15px 20px;
      border-radius: 10px;
      border: 2px solid rgba(102, 255, 255, 0.5);
      background: rgba(255,255,255,0.15);
      color: #e0e0e0;
      font-size: 1.2rem;
      outline: none;
      box-shadow: 0 0 15px rgba(102, 255, 255, 0.2);
      transition: all 0.3s ease;
    }
    #mainSearchInput:focus {
      border-color: #00ffff;
      box-shadow: 0 0 20px rgba(0, 255, 255, 0.4);
    }

    #advancedSearchOptions {
      background: rgba(10, 15, 36, 0.9);
      border-radius: 10px;
      padding: 20px;
      margin-top: 15px;
      box-shadow: 0 5px 20px rgba(0, 0, 0, 0.5);
      display: none;
      flex-direction: column;
      gap: 15px;
      border: 1px solid rgba(102, 255, 255, 0.3);
      
      /* Corrected Positioning */
      position: absolute;
      width: 100%; /* Take full width of parent searchContainer */
      top: calc(100% + 10px); /* Position below mainSearchInput + 10px space */
      left: 0; /* Align to the left edge of searchContainer */
      z-index: 100; /* Ensure it's above other content */
    }
    #advancedSearchOptions.active {
        display: flex;
    }

    #advancedSearchOptions label {
        color: #b0e0e6;
        font-size: 1rem;
        margin-bottom: -5px;
    }

    /* New styles for project grid */
    #projectList {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 30px;
      margin-top: 30px;
    }

    .project-card {
      background: #fff;
      padding: 15px;
      border-radius: 12px;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
      display: flex;
      flex-direction: column;
      overflow: hidden;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
      position: relative;
      color: #333;
    }

    .project-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.2);
    }

    .project-card-image {
      /* Removed calc and negative margins, relying on padding of parent */
      width: 100%;  
      height: 180px;
      background-color: #f0f0f0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 5rem;
      color: #ccc;
      overflow: hidden;
      border-radius: 12px 12px 0 0;
      position: relative;
      margin: -15px -15px 15px -15px; /* Apply negative margin to consume parent padding */
    }
    .project-card-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .project-card h3 {
      font-size: 1.5rem;
      margin: 15px 0 8px; /* Adjusted margin for better spacing after image */
      color: #222;
    }
    .project-card .description {
      font-size: 0.95rem;
      color: #555;
      margin-bottom: 15px;
      flex-grow: 1;
    }
    .project-card .roles {
      font-size: 0.9rem;
      color: #777;
      margin-bottom: 10px;
    }
    .project-card .status {
      font-size: 0.95rem;
      font-weight: bold;
      color: #007bff;
      margin-top: auto;
    }

    .btn-apply {
      position: absolute;
      bottom: 15px;
      right: 15px;
      background: linear-gradient(45deg, #007bff, #00c0ff);
      color: white;
      border: none;
      padding: 10px 15px;
      border-radius: 8px;
      cursor: pointer;
      font-size: 1rem;
      font-weight: 500;
      transition: all 0.3s ease;
      box-shadow: 0 3px 10px rgba(0, 123, 255, 0.3);
    }
    .btn-apply:hover {
      background: linear-gradient(45deg, #0056b3, #008fcc);
      transform: translateY(-2px);
      box-shadow: 0 5px 12px rgba(0, 123, 255, 0.5);
    }

    #applyModal {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0,0,0,0.7);
      justify-content: center;
      align-items: center;
      z-index: 2000;
    }
    #applyModal .modal-box {
      background: rgba(10, 15, 36, 0.9);
      padding: 30px;
      border-radius: 15px;
      width: 90%;
      max-width: 550px;
      position: relative;
      box-shadow: 0 0 40px rgba(0,0,0,0.6);
      color: #e0e0e0;
    }
    #applyModal .modal-box span {
      position: absolute;
      top: 15px;
      right: 20px;
      cursor: pointer;
      font-weight: bold;
      font-size: 1.8rem;
      color: #66ffff;
      transition: color 0.2s ease;
    }
    #applyModal .modal-box span:hover {
      color: #00ffff;
    }
    #applyModal .modal-box h3 {
      color: #66ffff;
      margin-top: 0;
      margin-bottom: 25px;
      font-size: 2rem;
      text-align: center;
    }
    #applyModal .modal-box label {
        color: #b0e0e6;
        font-size: 1rem;
        margin-bottom: 5px;
        display: block;
    }
    #applyModal .modal-box .btn {
        width: 100%;
        margin-top: 20px;
        padding: 12px 25px;
        font-size: 17px;
    }

    /* Search button styling */
    .btn.search-btn {
        padding: 12px 25px;
        font-size: 17px;
        background: linear-gradient(45deg, #007bff, #00c0ff);
        color: white;
        border: none;
        border-radius: 10px;
        cursor: pointer;
        font-weight: 600;
        transition: all 0.3s ease;
        box-shadow: 0 4px 12px rgba(0, 123, 255, 0.3);
        display: block;
        margin: 20px auto 0 auto;
    }
    .btn.search-btn:hover {
        background: linear-gradient(45deg, #0056b3, #008fcc);
        transform: translateY(-3px);
        box-shadow: 0 6px 15px rgba(0, 123, 255, 0.5);
    }

    /* Back button style */
    #backButton {
      background: none;
      border: 2px solid #66ffff;
      color: #66ffff;
      padding: 10px 15px;
      border-radius: 8px;
      cursor: pointer;
      font-size: 1rem;
      font-weight: 500;
      transition: all 0.3s ease;
      display: none;
    }
    #backButton:hover {
      background: #66ffff;
      color: #0a0f24;
      box-shadow: 0 0 15px rgba(102, 255, 255, 0.5);
    }

    /* Just paste your entire <style> block from before */
  </style>
</head>
<body>

<div class="navbar">
  <div class="brand"><strong>🌟 CollabSpace</strong></div>
  <div class="hamburger" onclick="toggleMenu()">☰</div>
  <div class="nav-links" id="navLinks">
    <a href="index.html">Home</a>
    <a href="post-idea.html">Post Idea</a>
    <a href="dashboard.html">Dashboard</a>
    <a href="apply.html">Apply</a>
    <a href="chat.html">Chat</a>
    <a href="interview.html">Interview</a>
    <a href="history.html">History</a>
    <a href="#" onclick="logout()">Logout</a>
  </div>
</div>

<div class="container">
  <h2>🔍 Find a Project to Join</h2>

  <div id="searchContainer">
    <button id="backButton" onclick="resetAndShowAllProjects()">&#8592; Back</button>
    <input type="text" id="mainSearchInput" placeholder="Search by Project Title or keyword..." onfocus="showAdvancedSearch()">
    <div id="advancedSearchOptions">
      <label>Select Roles you can fill:</label>
      <select id="userRoles" multiple size="6">
        <option>Frontend Developer</option>
        <option>Backend Developer</option>
        <option>UI/UX Designer</option>
        <option>Tester</option>
        <option>Content Writer</option>
        <option>Marketing</option>
      </select>
      <input id="customUserRole" placeholder="Other role (optional)">
      <button class="btn search-btn" id="triggerSearchButton">Search Projects</button>
    </div>
  </div>

  <div id="projectList"></div>
</div>

<div id="applyModal">
  <div class="modal-box">
    <span onclick="closeModal()">×</span>
    <h3>Apply to Project</h3>
    <label>Select Role:</label>
    <select id="selectedRole"></select>
    <label>Your Name:</label>
    <input id="applicantName" placeholder="Your name">
    <label>Your Email:</label>
    <input id="applicantEmail" placeholder="Your email">
    <label>Message (optional):</label>
    <textarea id="applicationMessage" placeholder="Message (optional)"></textarea>
    <button class="btn" onclick="submitApplication()">Submit Application</button>
  </div>
</div>

<!-- Firebase Scripts -->
<script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-app.js"></script>
<script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-auth.js"></script>
<script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-firestore.js"></script>

<!-- Main Script -->
<script>
document.addEventListener("DOMContentLoaded", () => {
  const firebaseConfig = {
    apiKey: "AIzaSyBbTWt0dpw7w6mFJB2yF0olTCh2mBDwbn8",
    authDomain: "collabspace-6d0af.firebaseapp.com",
    projectId: "collabspace-6d0af"
  };
  firebase.initializeApp(firebaseConfig);
  const db = firebase.firestore();

  const userEmail = localStorage.getItem("email") || "unknown@example.com";
  const userName = localStorage.getItem("username") || "Unknown User";

  let selectedId = "", selectedRoles = {}, appliedProjects = {};

  const mainSearchInput = document.getElementById("mainSearchInput");
  const advancedSearchOptions = document.getElementById("advancedSearchOptions");
  const backButton = document.getElementById("backButton");
  const userRolesSelect = document.getElementById("userRoles");
  const customUserRoleInput = document.getElementById("customUserRole");
  const triggerSearchButton = document.getElementById("triggerSearchButton");
  const projectList = document.getElementById("projectList");

  function showAdvancedSearch() {
    advancedSearchOptions.classList.add("active");
  }

  function hideAdvancedSearch() {
    advancedSearchOptions.classList.remove("active");
  }

  async function findProjects() {
    const searchKeyword = mainSearchInput.value.trim().toLowerCase();
    const selectedRolesArr = Array.from(userRolesSelect.selectedOptions).map(o => o.value.trim());
    const customRole = customUserRoleInput.value.trim();
    const skills = [...selectedRolesArr, ...(customRole ? [customRole] : [])];

    try {
      const apps = await db.collection("applications").where("email", "==", userEmail).get();
      apps.forEach(doc => appliedProjects[doc.data().projectId] = true);

      const snap = await db.collection("ideas").get();
      projectList.innerHTML = "";
      let foundProjects = false;

      snap.forEach(doc => {
        const data = doc.data();
        const projectId = doc.id;
        const projectTitle = data.title ? data.title.toLowerCase() : '';
        const projectDescription = data.description ? data.description.toLowerCase() : '';
        const availableRoles = data.roles || {};

        const titleMatches = searchKeyword === '' || projectTitle.includes(searchKeyword) || projectDescription.includes(searchKeyword);

        let roleMatches = false;
        if (skills.length === 0) {
          roleMatches = true;
        } else {
          for (const skill of skills) {
            if (availableRoles[skill] && availableRoles[skill] > 0) {
              roleMatches = true;
              break;
            }
          }
        }

        if (titleMatches && roleMatches) {
          foundProjects = true;
          const hasVacancy = Object.values(availableRoles).some(c => c > 0);
          const alreadyApplied = appliedProjects[projectId];

          let roleText = Object.entries(availableRoles).map(r => `${r[0]}: ${r[1]}`).join(", ");
          let buttonHTML = "";
          let statusText = "";

          if (alreadyApplied) {
            statusText = `<span class="status" style="color:#b0e0e6;">Already Applied</span>`;
          } else if (!hasVacancy) {
            statusText = `<span class="status" style="color:#ff6b6b;">All roles filled</span>`;
          } else {
            statusText = `<span class="status" style="color:#28a745;">Open for Applications</span>`;
            buttonHTML = `<button class="btn-apply" onclick='openApplyModal("${projectId}", ${JSON.stringify(availableRoles)})'>Apply</button>`;
          }

          projectList.innerHTML += `
            <div class="project-card">
              <div class="project-card-image">
                <i class="fas fa-project-diagram"></i>
              </div>
              <h3>${data.title}</h3>
              <p class="description">${data.description}</p>
              <p class="roles"><strong>Roles:</strong> ${roleText}</p>
              ${statusText}
              ${buttonHTML}
            </div>`;
        }
      });

      if (!foundProjects) {
        projectList.innerHTML = `<p style="text-align: center; color: #c0c0c0;">No matching projects found.</p>`;
      }
    } catch (err) {
      console.error("🔥 Firestore read error:", err.message);
      projectList.innerHTML = `<p style="text-align: center; color:#ff6b6b;">Error loading projects. Please try again.</p>`;
    } finally {
      hideAdvancedSearch();
      if (searchKeyword !== '' || skills.length > 0) {
        backButton.style.display = 'inline-block';
      } else {
        backButton.style.display = 'none';
      }
    }
  }

  triggerSearchButton.addEventListener('click', findProjects);
  mainSearchInput.addEventListener('keyup', findProjects);

  function resetAndShowAllProjects() {
    mainSearchInput.value = '';
    for (let i = 0; i < userRolesSelect.options.length; i++) {
      userRolesSelect.options[i].selected = false;
    }
    customUserRoleInput.value = '';
    backButton.style.display = 'none';
    findProjects();
  }

  function openApplyModal(id, roles) {
    selectedId = id;
    selectedRoles = roles;
    const roleSelect = document.getElementById("selectedRole");
    roleSelect.innerHTML = "";
    for (const r in roles) {
      if (roles[r] > 0) {
        const opt = document.createElement("option");
        opt.value = r;
        opt.textContent = r;
        roleSelect.appendChild(opt);
      }
    }
    document.getElementById("applicantName").value = userName;
    document.getElementById("applicantEmail").value = userEmail;
    document.getElementById("applicationMessage").value = "";
    document.getElementById("applyModal").style.display = "flex";
  }

  async function submitApplication() {
    const role = document.getElementById("selectedRole").value;
    const name = document.getElementById("applicantName").value;
    const email = document.getElementById("applicantEmail").value;
    const message = document.getElementById("applicationMessage").value;

    if (!role || !name || !email) {
      alert("Please fill all required fields");
      return;
    }

    try {
      await db.collection("applications").add({
        projectId: selectedId,
        name,
        email,
        role,
        message,
        timestamp: firebase.firestore.FieldValue.serverTimestamp()
      });
      alert("Application submitted!");
      closeModal();
      findProjects();
    } catch (err) {
      console.error("Error submitting application:", err.message);
      alert("Something went wrong. Please try again.");
    }
  }

  function closeModal() {
    document.getElementById("applyModal").style.display = "none";
  }

  window.logout = function() {
    localStorage.clear();
    window.location.href = "login.html";
  }

  window.toggleMenu = function() {
    const nav = document.getElementById("navLinks");
    nav.classList.toggle("active");
  }

  findProjects(); // Trigger initial load
});
</script>

</body>
</html>
